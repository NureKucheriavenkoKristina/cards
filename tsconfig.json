{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@cardly/srs": [
        "./packages/srs/src/index.ts"
      ],
      "@cardly/srs/*": [
        "./packages/srs/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "supabase/functions"
  ]
}
