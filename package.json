{
  "name": "cardly",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas-cli build --platform android --profile preview",
    "build:android:download": "eas-cli build:download --platform android --latest --output dist/cardly-preview.apk",
    "supabase": "supabase",
    "test": "npm run test:app",
    "test:watch": "npm run test:app:watch",
    "test:app": "jest --config jest.app.config.cjs --runInBand",
    "test:app:watch": "jest --config jest.app.config.cjs --watch",
    "test:srs": "npm --workspace=@cardly/srs run test",
    "test:srs:watch": "npm --workspace=@cardly/srs run test:watch"
  },
  "dependencies": {
    "@cardly/srs": "*",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~54.0.33",
    "expo-auth-session": "~6.0.3",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.12",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.17",
    "expo-print": "^55.0.14",
    "expo-router": "~6.0.23",
    "expo-sharing": "^55.0.18",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react-native": "^0.563.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eas-cli": "^19.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "supabase": "^2.84.4",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "private": true
}
